# ─────────────────────────────────────────────────────────────────
# BotTorik v2.0 — Environment Variables
# Di Railway: masuk ke project → Variables → tambah satu per satu
# ─────────────────────────────────────────────────────────────────

# ── KEAMANAN DASHBOARD (WAJIB DIUBAH!) ──
DASHBOARD_PASSWORD=GantiPasswordIniSekarang!
DASHBOARD_SECRET=kata-rahasia-panjang-acak-bebas

# ── AI Keys (opsional, untuk mode AI) ──
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...

# ── Bot Config ──
BOT_NAME=BotTorik
BOT_MODE=ai
AUTO_REPLY_MESSAGE=Halo! Lagi tidak bisa balas, nanti saya hubungi ya 😊
REPLY_COOLDOWN_MINUTES=0
BIZ_CONTEXT=Toko online yang menjual berbagai produk berkualitas.
ADMIN_WA=+6281234567890

# ── SMTP Email (opsional) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=emailkamu@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Toko Kamu <emailkamu@gmail.com>

# ── Keyword Custom ──
CUSTOM_KEYWORDS=[{"keyword":"harga","reply":"Harga mulai Rp 50.000!"},{"keyword":"alamat","reply":"Jl. Merdeka No. 1 Bandung"}]

# ── Railway otomatis set ini, jangan diubah ──
# PORT=3000
